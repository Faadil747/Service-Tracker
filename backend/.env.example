# ─── App ─────────────────────────────────────────────────────────────────────
# Generate a strong random string, e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (SQLite — no install required):
DATABASE_URL=sqlite+aiosqlite:///./service_tracker.db

# Production (MySQL, async driver):
# DATABASE_URL=mysql+asyncmy://USER:PASSWORD@HOST:3306/DBNAME
# Set DB_SSL=true if your managed MySQL requires TLS (Aiven, TiDB Cloud, PlanetScale).
DB_SSL=false
# Optional: path to the host's CA cert for strict TLS verification. Leave empty to
# encrypt without verifying the server cert (connects out-of-box with managed hosts).
DB_SSL_CA=

# ─── AI (DeepSeek) — optional, can also be set in-app via Settings → API ───────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── LinkedIn — optional, can also be set in-app via Settings → API ────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Use your PRODUCTION backend URL in prod:
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/linkedin/callback
LINKEDIN_ORG_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PROXY_URL=http://localhost:3001

# ─── Public backend URL — used to build shareable tracking links ──────────────
# In production set to your Render URL, e.g. https://your-api.onrender.com
BACKEND_PUBLIC_URL=http://localhost:8000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your deployed frontend origin (Vercel). Extra origins can be comma-separated in
# ALLOWED_ORIGINS. Vercel *.vercel.app preview URLs are allowed automatically.
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=

# ─── First admin (used by: python -m app.seed.create_admin) ────────────────────
ADMIN_EMAIL=admin@gorecruitai.com
ADMIN_PASSWORD=change-this-strong-password
ADMIN_NAME=Administrator

# ─── Email (optional) ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gorecruitai.com

# ─── Feature Flags ────────────────────────────────────────────────────────────
DEV_MODE=false
