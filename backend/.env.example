# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-32-char-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (local dev — no install required):
DATABASE_URL=sqlite+aiosqlite:///./service_tracker.db

# MS SQL Server (production):
# DATABASE_URL=mssql+pyodbc://username:password@server/database?driver=ODBC+Driver+17+for+SQL+Server
DB_SERVER=your-db-server.database.windows.net
DB_DATABASE=your-db-name
DB_UID=your-db-username
DB_PWD=your-db-password
DB_DRIVER=ODBC Driver 18 for SQL Server

# ─── AI (DeepSeek) ────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── LinkedIn OAuth ───────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your-linkedin-app-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-app-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/auth/linkedin/callback
LINKEDIN_ORG_ID=your-organization-id

# LinkedIn proxy URL (Developer role sandbox)
LINKEDIN_PROXY_URL=http://localhost:3001

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@gorecruitai.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Feature Flags ────────────────────────────────────────────────────────────
DEV_MODE=true
