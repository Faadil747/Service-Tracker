# SocialTracker backend — self-hosted (Windows VPS + MS SQL Server).
# Copy this file to  backend\.env  and fill in the CHANGE_ME values.

# ── Database: your MS SQL Server (connected via SSMS) ───────────────────────
DB_SERVER=P3NWPLSK12SQL-v08.shr.prod.phx3.secureserver.net
DB_DATABASE=LinkedInTest
DB_UID=LinkedInTest
DB_PWD=CHANGE_ME_your_sql_password
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_ENCRYPT=false

# ── First admin login (created automatically on first start) ────────────────
ADMIN_EMAIL=admin@gorecruitai.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
ADMIN_NAME=Administrator

# ── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_random_long_secret_string
DEV_MODE=false
# This one process also serves the UI, so no separate FRONTEND_URL/CORS is needed.

# ── LinkedIn (optional — can also be set later in the app's Settings page) ──
LINKEDIN_ORG_ID=15078287
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=

# ── AI (optional) ───────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# ── External daily-sync cron secret (optional) ──────────────────────────────
CRON_SECRET=
